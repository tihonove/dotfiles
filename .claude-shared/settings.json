      "NotebookEdit",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(mv *)",
      "Bash(cp *)",
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(tee *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(find *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(perl *)",
      "Bash(npx vitest *)",
      "Bash(npm run *)",
      "Bash(npx tsc *)",
      "Bash(node -e ' *)",
