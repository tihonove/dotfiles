#!/bin/bash
# Читаем ввод и кодируем в base64, удаляя переносы строк
B64=$(cat | base64 | tr -d '\n\r')

# Проверяем, запущен ли скрипт внутри tmux
if [ -n "$TMUX" ]; then
    # Отправляем обертку для tmux напрямую в терминал (минуя stdout lazygit)
    printf "\033Ptmux;\033\033]52;c;%s\007\033\\" "$B64" > /dev/tty
else
    # Стандартный вывод для обычного SSH без tmux
    printf "\033]52;c;%s\007" "$B64" > /dev/tty
fi